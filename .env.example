# 必須: LLM プロバイダーの API キー (Anthropic / OpenAI のいずれか、または両方)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# 必須: Tavily 検索 API キー (path_executor が外部ソース grounding に使用)
TAVILY_API_KEY=tvly-...

# 任意: LangSmith トレース (空のままなら無効)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=langgraph-peer-review-agent
